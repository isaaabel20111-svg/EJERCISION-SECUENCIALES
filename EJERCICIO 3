//PROCESO PARA CALCULAR LA HIPOTENUSA DE UN TRIANGULO RECTANGULO DADO LOS 2 CATETOS
PROCESO BIENVENIDA
 ESCRIBIR "PROGRAMA QUE VA A AYUDAR A CALCULAR LA HIPOTENUSA DE UN TRIANGULO RECTANGULO DADO LOS 2 CATETOS"
 ESCRIBIR "ESCRIBE EL VALOR DEL CATETO1"
 LEER CATETO1
 ESCRIBIR "ESCRIBE EL VALOR DEL CATETO2"
 LEER CATETO2
 RESULTADO = RAIZ ((CATETO1 * CATETO1) + (CATETO2 * CATETO2))
 ESCRIBIR "SI EL CATETO1 MIDE ", CATETO1, " Y EL CATETO2 ", CATETO2, ", ENTONCES LA HIPOTENUSA DEL TRIANGULO RECTANGULO MIDE ", RESULTADO
FINPROCESO

// PROCESO QUE PASAR DE GRADOS FAHRENHEIT A GRADOS CELSIUS
PROCESO DEGRADOSFAHRENHEITACELSIUS
 ESCRIBIR "BIENVENIDO AL PROGRAMA QUE TE VA A PASAR DE GRADOS FAHRENHEIT A GRADOS CELSIUS"
 ESCRIBIR "ESCRIBE EL GRADO EN FAHRENHEIT"
 LEER FAHRENHEIT
 RESULTADO = (FAHRENHEIT - 32) * 5 / 9 
 ESCRIBIR "SI EL GRADO EN FAHRENHEIT ES ", FAHRENHEIT, " GRADOS, ENTONCES EN GRADOS CELSIUS SERIAN ",RESULTADO, " GRADOS"
FINPROCESO

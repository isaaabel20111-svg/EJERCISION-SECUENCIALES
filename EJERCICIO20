Algoritmo CalcularDinero
    Definir m2e, m1e, m50c, m20c, m10c Como Entero
    Definir totalCentimos, eurosFinales, centimosSobrantes Como Entero
    
    Escribir "Cantidad de monedas de 2 Euros:"
    Leer m2e
    Escribir "Cantidad de monedas de 1 Euro:"
    Leer m1e
    Escribir "Cantidad de monedas de 50 Céntimos:"
    Leer m50c
    Escribir "Cantidad de monedas de 20 Céntimos:"
    Leer m20c
    Escribir "Cantidad de monedas de 10 Céntimos:"
    Leer m10c
    
    // Calculamos todo en la unidad mínima (céntimos)
    totalCentimos <- (m2e * 200) + (m1e * 100) + (m50c * 50) + (m20c * 20) + (m10c * 10)
    
    // Obtenemos los euros totales (parte entera de la división por 100)
    eurosFinales <- TRUNC(totalCentimos / 100)
    
    // Obtenemos los céntimos restantes (el residuo de la división)
    centimosSobrantes <- totalCentimos MOD 100
    
    Escribir "---------------------------------------"
    Escribir "Tienes un total de:"
    Escribir eurosFinales, " Euros con ", centimosSobrantes, " céntimos."
    Escribir "---------------------------------------"
FinAlgoritmo

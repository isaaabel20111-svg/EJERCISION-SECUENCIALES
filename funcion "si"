Algoritmo edad
	//REALIZAR  UN PROGRAMA  QUE CAPTURE  LA EDAD DE UNA PERSONA Y DETERMINE  SI ES MAYOR DE EDAD I 
	Escribir "PROGRAMA QUE DETERMINA  LA MAYORIA DE EDAD DE UNA PERSONA"
	Escribir "BUENAS "
	Escribir "DIGITE SU NOMBRE" 
	Leer  NOMBRE 
	Escribir "DIGITE SU EDAD " 
	LEER EDAD1
	SI EDAD1 <=  18 Entonces
	ESCRIBIR nombre ,"es mayor de edad"
SiNo
	Escribir  nombre ," ES MENOR DE EDAD "
	FinSi
FinAlgoritmo

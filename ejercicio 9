# Entrada de datos
total_compra = float(input("Ingrese el total de la compra: "))

# Procesamiento
descuento = total_compra * 0.15
pago_final = total_compra - descuento

# Salida de resultados
print(f"\n--- Resumen de Compra ---")
print(f"Total original: ${total_compra:.2f}")
print(f"Descuento aplicado (15%): ${descuento:.2f}")
print(f"Monto final a pagar: ${pago_final:.2f}") 

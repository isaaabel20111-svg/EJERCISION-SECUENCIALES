//PROCESO PARA CALCULAR SUMA, RESTA, MULTIPLICACION Y DIVISION DE DOS NUMEROS
PROCESO SUMA,RESTA,MULTIPLICACIONYDIVISION
 ESCRIBIR "BIENVENIDO AL PROGRAMA QUE TE VA A AYUDAR A SACAR LA SUMA, RESTA, MULTIPLICACION Y DIVICION DE DOS NUMEROS"
 ESCRIBIR "ESCRIBE NUM1"
 LEER NUM1
 ESCRIBIR "ESCRIBE NUM2"
 LEER NUM2
 RESULTADOSUMA = NUM1 + NUM2
 RESULTADORESTA = NUM1 - NUM2
 RESULTADOMULTIPLICACION = NUM1 * NUM2
 RESULTADODIVISION = NUM1 / NUM2
 ESCRIBIR "SI EL PRIMER NUMERO ES ", NUM1, " Y EL SEGUNDO ", NUM2, ", ENTONCES EL RESULTADO DE LA SUMA ES ", RESULTADOSUMA, ", EL DE LA RESTA ", RESULTADORESTA, ", EL DE LA MULTIPLICACION ", RESULTADOMULTIPLICACION, " Y EL DE LA DIVISION ", RESULTADODIVISION
FINPROCESO

// PROGRMA QUE VA A CALCULAR EL AREA Y PERIMETRO DE UN RECTANGULO
Proceso AREAYPERIMETRORECTANGULAR
 ESCRIBIR "PROGRAMA QUE VA A CALCULA EL AREA Y PERIMETRO DE UN RECTANGULO"
 ESCRIBIR "ESCRIBE EL VALOR DE LA BASE"
 LEER BASE
 ESCRIBIR "ESCRIBE EL VALOR DE LA ALTURA"
 LEER ALTURA
 RESULTADO1 = BASE * ALTURA
 RESULTADO2 = 2 * ( BASE + ALTURA )
 ESCRIBIR "SI LA BASE DEL RECTANGULO ES ", BASE, " Y DE LA ALTURA ES ", ALTURA, ", EL RECTANGULO TIENE UN AREA DE ", RESULTADO1, " Y UN PERIMETRO DE ", RESULTADO2
FinProceso
